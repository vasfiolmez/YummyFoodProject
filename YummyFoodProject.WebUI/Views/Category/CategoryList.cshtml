
@{
    ViewData["Title"] = "CategoryList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@model List<ResultCategoryDto>
@* Kendi DTO namespace'ini projene göre yukarıya ekleyebilirsin *@

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4>Kategori Yönetimi</h4>
                <a href="/Category/CreateCategory" class="btn btn-primary btn-icon icon-left">
                    <i class="fas fa-plus"></i> Yeni Kategori Ekle
                </a>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-md">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 5%;">#</th>
                                <th scope="col" style="width: 65%;">Kategori Adı</th>
                                <th scope="col" style="width: 30%; text-align: center;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <th scope="row">@count</th>
                                        <td>
                                            <span class="font-weight-600">@item.CategoryName</span>
                                        </td>
                                        <td class="text-center">
                                            <a href="/Category/UpdateCategory/@item.CategoryId" class="btn btn-warning btn-sm btn-icon icon-left">
                                                <i class="fas fa-edit"></i> Güncelle
                                            </a>

                                            <a href="/Category/DeleteCategory/@item.CategoryId" class="btn btn-danger btn-sm btn-icon icon-left ml-1" onclick="return confirm('@item.CategoryName isimli kategoriyi silmek istediğinize emin misiniz?');">
                                                <i class="fas fa-trash"></i> Sil
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center p-4 text-muted">
                                        <i class="fas fa-folder-open mb-2" style="font-size: 24px;"></i><br />
                                        Henüz sisteme eklenmiş bir kategori bulunmamaktadır.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

