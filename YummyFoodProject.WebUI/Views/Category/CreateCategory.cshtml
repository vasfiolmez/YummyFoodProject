@model CreateCategoryDto
@{
    ViewData["Title"] = "Kategori Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="row mt-4">
    <div class="col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3">
        <div class="card card-primary">
            <div class="card-header">
                <h4><i class="fas fa-plus-circle mr-2"></i> Yeni Kategori Ekle</h4>
            </div>

            <div class="card-body">
                <form method="post" action="/Category/CreateCategory">

                    <div class="form-group">
                        <label>Kategori Adı</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <div class="input-group-text">
                                    <i class="fas fa-tag"></i>
                                </div>
                            </div>
                            <input type="text" class="form-control" name="CategoryName" required placeholder="Örn: Tatlılar, Ana Yemekler..." autocomplete="off">
                        </div>
                        <small class="form-text text-muted">Restoran menünüzde görünecek olan kategori adını giriniz.</small>
                    </div>

                    <div class="form-group mb-0 text-right">
                        <a href="/Category/CategoryList" class="btn btn-secondary mr-2">
                            <i class="fas fa-times"></i> İptal
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>