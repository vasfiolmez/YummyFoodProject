<section id="chefs" class="chefs section">

    <div class="container section-title" data-aos="fade-up">
        <h2>Şeflerimiz</h2>
        <p><span>Profesyonel</span> <span class="description-title">Mutfak Kadromuz<br></span></p>
    </div>

    <div class="container">
        <div class="row gy-4">

            @{
                int delay = 100;
            }
            @foreach (var item in Model)
            {
                <div class="col-lg-4 d-flex align-items-stretch" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="team-member">
                        <div class="member-img">
                            <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name" style="width: 100%; height: 450px; object-fit: cover;">
                            <div class="social">
                                <a href="#"><i class="bi bi-twitter-x"></i></a>
                                <a href="#"><i class="bi bi-facebook"></i></a>
                                <a href="#"><i class="bi bi-instagram"></i></a>
                                <a href="#"><i class="bi bi-linkedin"></i></a>
                            </div>
                        </div>
                        <div class="member-info">
                            <h4>@item.Name</h4>
                            <span>@item.Title</span>
                            <p>@item.Description</p>
                        </div>
                    </div>
                </div>
                delay += 100; // Her şef için animasyon gecikmesini artırır
            }

        </div>
    </div>

</section>